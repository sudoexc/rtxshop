    </div>
  </div>
</section>

<!-- TOP PRODUCTS -->
<section style="padding:64px 0;">
  <div class="container">
    <div class="catalog-header reveal" style="margin-bottom:40px;">
      <div class="section-eyebrow" data-i18n="bp_products_eyebrow">Каталог</div>
      <h2 class="section-title"><span data-i18n="bp_products_title">Популярные товары</span> <span class="accent-text">GravaStar</span></h2>
    </div>
    <div id="gravaProductsGrid" class="brand-photo-grid">
      <div class="catalog-loading"><div class="catalog-spinner"></div></div>
    </div>
    <div style="text-align:center;margin-top:36px;">
      <a href="/catalog?brand=GravaStar" class="btn-primary">Весь каталог GravaStar →</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="b2b-proof">
  <div class="container">
    <div class="b2bp-inner">
      <div class="b2bp-stats">
        <div class="b2bp-stat"><div class="b2bp-num">GravaStar</div><div class="b2bp-label">Sci-fi gaming peripherals</div></div>
        <div class="b2bp-divider"></div>
        <div class="b2bp-stat"><div class="b2bp-num">MOQ 3+</div><div class="b2bp-label" data-i18n="b2bp_stat3">Minimum order from 3 units</div></div>
        <div class="b2bp-divider"></div>
        <div class="b2bp-stat"><div class="b2bp-num">UZB</div><div class="b2bp-label">Nationwide delivery</div></div>
      </div>
      <div class="b2bp-text">
        <div class="b2bp-eyebrow" data-i18n="bp_cta_title">Стать дилером</div>
        <h2><span>Продавайте GravaStar</span><br><span class="accent-text">в своём магазине</span></h2>
        <p data-i18n="bp_cta_sub">Оставьте заявку и получите оптовый прайс в течение 2 часов.</p>
        <div class="b2bp-actions">
          <a href="/become-partner" class="btn-primary" data-i18n="bp_hero_cta1">Стать партнёром</a>
          <a href="https://t.me/iBazzaruz" target="_blank" rel="noopener" class="btn-secondary">Telegram</a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/modals') %>

<script>
  window._brandPageBrand = 'GravaStar';
</script>
<script src="/js/main.js" defer></script>
<script>
(function waitBrandPage() {
  if (typeof _catalogAll === 'undefined' || !_catalogAll.length) {
    return setTimeout(waitBrandPage, 100);
  }
  const grid = document.getElementById('gravaProductsGrid');
  if (!grid) return;
  const products = _catalogAll.filter(p => p.brand === 'GravaStar').slice(0, 8);
  if (!products.length) { grid.innerHTML = ''; return; }
  grid.innerHTML = products.map(p => {
    const badge = p.badge ? `<span class="bpc-badge bpc-badge--${p.badge.toLowerCase()}">${p.badge}</span>` : '';
    const img = p.image_url
      ? `<img src="${p.image_url.replace(/(\.[^./?#]+)(\?.*)?$/, '-sm.webp')}" alt="${p.name}" loading="lazy" />`
      : '';
    return `<div class="bpc" onclick="openProductModal('${p.id}')">
      <div class="bpc-img">${badge}<span class="bpc-stock">In stock</span>${img}</div>
      <div class="bpc-body">
        <div class="bpc-type">${p.category}</div>
        <div class="bpc-name">${p.name}</div>
        <div class="bpc-actions" onclick="event.stopPropagation()">
          <button class="bpc-btn bpc-btn--info" onclick="openProductModal('${p.id}')">Details</button>
          <a href="/become-partner" class="bpc-btn bpc-btn--price">Request Price</a>
        </div>
      </div>
    </div>`;
  }).join('');
})();
</script>
</body>
</html>
