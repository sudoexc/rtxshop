<!DOCTYPE html>
<html lang="ru">
<head>
  <%- include('../partials/head', {
    title: 'Стать партнёром — RTXSHOP | Дистрибьютор ATK, GravaStar, Arctic',
    desc: 'Стать официальным дилером RTXSHOP. Оптовые цены, персональный менеджер, официальная гарантия. Оставьте заявку — ответим за 2 часа.',
    path: '/become-partner'
  }) %>
</head>
<body>

<%- include('../partials/floats') %>
<%- include('../partials/navbar', { page: 'b2b' }) %>

<!-- HERO -->
<section class="hero" id="home" style="min-height:55vh;padding-top:140px;padding-bottom:60px;">
  <div class="hero-inner" style="align-items:center;">
    <div class="hero-content" style="max-width:700px;">
      <div class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        <span data-i18n="partner_eyebrow">Партнёрская программа</span>
      </div>
      <h1>
        <span data-i18n="partner_h1a">Станьте</span><br>
        <span class="accent-text" data-i18n="partner_h1b">дилером RTXSHOP.</span>
      </h1>
      <p class="hero-sub" data-i18n="partner_sub">Заполните форму — наш менеджер свяжется с вами и подберёт индивидуальные условия для вашего бизнеса.</p>
      <div class="hero-pills">
        <span class="hero-pill"><span data-i18n="pill_warehouse">Локальный склад</span></span>
        <span class="hero-pill"><span data-i18n="pill_delivery">Доставка 1–2 дня</span></span>
        <span class="hero-pill"><span data-i18n="pill_warranty">Официальная гарантия</span></span>
        <span class="hero-pill"><span data-i18n="pill_pricing">Оптовые цены</span></span>
      </div>
    </div>
  </div>
</section>

<!-- MAIN CONTENT -->
<section style="padding:0 0 80px;">
  <div class="container">
    <div class="partner-page-grid">

      <!-- FORM -->
      <div class="partner-form-wrap reveal" id="partnerFormWrap">
        <h2 class="partner-form-title" data-i18n="pf_submit">Отправить заявку</h2>
        <form id="partnerForm" class="partner-form">
          <div class="pf-row">
            <div class="form-group">
              <label class="form-label" for="pf_name" data-i18n="pf_name">Ваше имя *</label>
              <input type="text" id="pf_name" name="name" class="form-input" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="pf_company" data-i18n="pf_company">Компания / Магазин *</label>
              <input type="text" id="pf_company" name="company" class="form-input" required />
            </div>
          </div>
          <div class="pf-row">
            <div class="form-group">
              <label class="form-label" for="pf_phone" data-i18n="pf_phone">Телефон *</label>
              <input type="tel" id="pf_phone" name="phone" class="form-input" placeholder="+998 90 000 00 00" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="pf_city" data-i18n="pf_city">Город</label>
              <input type="text" id="pf_city" name="city" class="form-input" placeholder="Ташкент" />
            </div>
          </div>
          <div class="pf-row">
            <div class="form-group">
              <label class="form-label" for="pf_volume" data-i18n="pf_volume">Ожидаемый объём в месяц</label>
              <input type="text" id="pf_volume" name="volume" class="form-input" data-i18n-placeholder="pf_volume_ph" placeholder="Например: 50–100 единиц" />
            </div>
            <div class="form-group">
              <label class="form-label" for="pf_brands" data-i18n="pf_brands">Интересующие бренды</label>
              <input type="text" id="pf_brands" name="brands" class="form-input" data-i18n-placeholder="pf_brands_ph" placeholder="ATK, GravaStar, Arctic, Picun" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="pf_messenger" data-i18n="pf_messenger">Telegram / WhatsApp</label>
            <input type="text" id="pf_messenger" name="messenger" class="form-input" data-i18n-placeholder="pf_messenger_ph" placeholder="@username или +998..." />
          </div>
          <div class="form-group">
            <label class="form-label" for="pf_message" data-i18n="pf_message">Расскажите о вашем магазине</label>
            <textarea id="pf_message" name="message" class="form-input" rows="3" style="resize:vertical;"></textarea>
          </div>
          <button type="submit" class="form-submit" id="partnerSubmitBtn">
            <span id="partnerSubmitText" data-i18n="pf_submit">Отправить заявку</span>
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>
        <div class="form-success" id="partnerSuccess" style="display:none;">
          <div class="form-success-check"><svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
          <h3 data-i18n="pf_success_title">Заявка отправлена!</h3>
          <p data-i18n="pf_success_sub">Наш менеджер свяжется с вами в течение 2 рабочих часов.</p>
        </div>
      </div>

      <!-- BENEFITS SIDEBAR -->
      <div class="partner-benefits reveal reveal-delay-2">
        <h3 data-i18n="partner_why_title">Что вы получаете</h3>
        <ul class="partner-benefits-list">
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw1">Оптовые цены напрямую</span></li>
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw2">Эксклюзивные акции для партнёров</span></li>
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw3">Маркетинговые материалы</span></li>
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw4">Персональный менеджер 24/7</span></li>
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw5">Официальная гарантия на всё</span></li>
          <li><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span data-i18n="pw6">Отсрочка платежа</span></li>
        </ul>
        <div class="partner-contact-alt">
          <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">Или напишите напрямую:</p>
          <a href="https://t.me/iBazzaruz" target="_blank" rel="noopener" class="btn-secondary" style="display:inline-flex;align-items:center;gap:8px;font-size:14px;">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            @iBazzaruz
          </a>
        </div>
        <div class="partner-brands-logos">
          <img src="/img/logos/atk-real.png" alt="ATK" />
          <img src="/img/logos/gravastar-real.png" alt="GravaStar" />
          <img src="/img/logos/arctic-real.svg" alt="Arctic" />
          <img src="/img/logos/picun-real.png" alt="Picun" />
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('../partials/footer') %>

<script src="/js/main.js" defer></script>
<script>
(function() {
  const form = document.getElementById('partnerForm');
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('partnerSubmitBtn');
    const txt = document.getElementById('partnerSubmitText');
    const data = {
      name:      form.name.value.trim(),
      company:   form.company.value.trim(),
      phone:     form.phone.value.trim(),
      city:      form.city.value.trim(),
      volume:    form.volume.value.trim(),
      brands:    form.brands.value.trim(),
      messenger: form.messenger.value.trim(),
      message:   form.message.value.trim(),
      type:      'partner_request'
    };
    if (!data.name || !data.phone || !data.company) return;
    btn.disabled = true;
    txt.textContent = '...';
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const result = await res.json();
      if (result.success) {
        form.style.display = 'none';
        document.getElementById('partnerSuccess').style.display = 'block';
      } else throw new Error();
    } catch {
      btn.disabled = false;
      txt.textContent = document.querySelector('[data-i18n="pf_submit"]')?.textContent || 'Отправить заявку';
    }
  });
})();
</script>
</body>
</html>
