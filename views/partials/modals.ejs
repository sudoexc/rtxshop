<!-- PRODUCT MODAL -->
<div class="product-modal" id="productModal" role="dialog" aria-modal="true">
  <div class="pm-overlay" onclick="closeProductModal()"></div>
  <div class="pm-dialog">
    <button type="button" class="pm-close" onclick="closeProductModal()" aria-label="Закрыть">
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <div class="pm-image-side">
      <div class="pm-gallery">
        <div class="pm-gallery-main" id="pmGalleryMain"></div>
        <div class="pm-gallery-thumbs" id="pmGalleryThumbs"></div>
      </div>
    </div>
    <div class="pm-content-side">
      <div>
        <div class="pm-badge"></div>
        <div class="pm-brand"></div>
        <div class="pm-name"></div>
      </div>
      <div class="pm-colors-wrap"></div>
      <div class="pm-specs"></div>
      <div class="pm-desc"></div>
      <div class="pm-moq-strip">
        <div class="pm-moq-item">
          <span class="pm-moq-label" data-i18n="moq_label">MOQ</span>
          <span class="pm-moq-val" data-i18n="moq_val">from 3 units</span>
        </div>
        <div class="pm-moq-item pm-moq-price">
          <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          <span data-i18n="moq_price">Wholesale price on request</span>
        </div>
      </div>
      <button type="button" class="pm-cta-btn" data-i18n="modal_cta">Запросить у менеджера</button>
    </div>
  </div>
</div>

<div class="pm-lightbox" id="pmLightbox">
  <div class="pm-lightbox-overlay" onclick="closeLightbox()"></div>
  <button type="button" class="pm-lightbox-prev" onclick="pmLightboxNav(-1)" aria-label="Назад">&#8249;</button>
  <div class="pm-lightbox-img-wrap" id="pmLightboxImg"></div>
  <button type="button" class="pm-lightbox-next" onclick="pmLightboxNav(1)" aria-label="Вперёд">&#8250;</button>
  <button type="button" class="pm-lightbox-close" onclick="closeLightbox()" aria-label="Закрыть">&#215;</button>
</div>
